flowchart TD
    %% =============================================================
    %% LangGraph Agent -- Workflow Diagram
    %% Generated by mermaid_diagram.py
    %% =============================================================

    %% ── Nodes ────────────────────────────────────────────────────
    START(("START"))
    END(("END"))

    answer["answer"]
    approval["approval"]
    clarify["clarify"]
    classify["classify"]
    dead_letter["dead_letter"]
    evaluate["evaluate"]
    finalize["finalize"]
    intake["intake"]
    retry["retry"]
    risky_action["risky_action"]
    tool["tool"]

    classify_cond{"route_after_classify"}
    evaluate_cond{"route_after_evaluate"}
    approval_cond{"route_after_approval"}
    retry_cond{"route_after_retry"}

    %% ── Edges ────────────────────────────────────────────────────
    START --> intake
    intake --> classify
    classify -->|"simple"| answer
    classify -->|"tool"| tool
    classify -->|"missing_info"| clarify
    classify -->|"risky"| risky_action
    classify -->|"error"| retry
    clarify --> finalize
    answer --> finalize
    tool --> evaluate
    evaluate -->|"needs_retry"| retry
    evaluate -->|"success"| answer
    risky_action --> approval
    approval -->|"approved"| tool
    approval -->|"rejected"| clarify
    retry -->|"attempt < max"| tool
    retry -->|"exhausted"| dead_letter
    dead_letter --> finalize
    finalize --> END

    %% ── Node styles ─────────────────────────────────────────────
    classDef intake_style fill:#6366f120,stroke:#6366f1,stroke-width:2px,color:#6366f1,font-weight:600
    class intake intake_style
    classDef classify_style fill:#818cf820,stroke:#818cf8,stroke-width:2px,color:#818cf8,font-weight:600
    class classify classify_style
    classDef answer_style fill:#22c55e20,stroke:#22c55e,stroke-width:2px,color:#22c55e,font-weight:600
    class answer answer_style
    classDef tool_style fill:#3b82f620,stroke:#3b82f6,stroke-width:2px,color:#3b82f6,font-weight:600
    class tool tool_style
    classDef evaluate_style fill:#f59e0b20,stroke:#f59e0b,stroke-width:2px,color:#f59e0b,font-weight:600
    class evaluate evaluate_style
    classDef clarify_style fill:#6b708820,stroke:#6b7088,stroke-width:2px,color:#6b7088,font-weight:600
    class clarify clarify_style
    classDef risky_action_style fill:#a855f720,stroke:#a855f7,stroke-width:2px,color:#a855f7,font-weight:600
    class risky_action risky_action_style
    classDef approval_style fill:#a855f720,stroke:#a855f7,stroke-width:2px,color:#a855f7,font-weight:600
    class approval approval_style
    classDef retry_style fill:#f59e0b20,stroke:#f59e0b,stroke-width:2px,color:#f59e0b,font-weight:600
    class retry retry_style
    classDef dead_letter_style fill:#ef444420,stroke:#ef4444,stroke-width:2px,color:#ef4444,font-weight:600
    class dead_letter dead_letter_style
    classDef finalize_style fill:#6366f120,stroke:#6366f1,stroke-width:2px,color:#6366f1,font-weight:600
    class finalize finalize_style
    classDef cond_style fill:#f59e0b15,stroke:#f59e0b,stroke-width:2px,color:#f59e0b,font-weight:700
    class classify_cond cond_style
    class evaluate_cond cond_style
    class approval_cond cond_style
    class retry_cond cond_style

